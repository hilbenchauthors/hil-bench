+
+// NewPrometheusInstance returns a Metrics instance for dependency injection.
+func NewPrometheusInstance(ds model.DataStore) Metrics {
+	return &metrics{ds: ds}
+}
 
+func ShouldRecordDBCountsForDetailLevel(level string) bool {
+	return level == "full" || level == "timestamps_only"
+}
+
+func (m *metrics) WriteInitialMetrics(ctx context.Context) {
+	pm := getPrometheusMetrics()
+	pm.versionInfo.With(prometheus.Labels{"version": consts.Version}).Set(1)
+	if ShouldRecordDBCountsForDetailLevel(conf.Server.Prometheus.DetailLevel) {
+		processSqlAggregateMetrics(ctx, m.ds, pm.dbTotal)
+	}
+}
+
+func (m *metrics) WriteAfterScanMetrics(ctx context.Context, success bool) {
+	pm := getPrometheusMetrics()
