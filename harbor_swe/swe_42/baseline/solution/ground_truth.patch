+	pm.lastMediaScan.With(scanLabels).SetToCurrentTime()
+	if success {
+		pm.mediaScansCounter.With(scanLabels).Inc()
+	}
+}
+
+func (m *metrics) GetHandler() http.Handler {
+	r := chi.NewRouter()
+	r.Use(middleware.Throttle(PrometheusMaxConcurrent))
+	if len(conf.Server.Prometheus.Password) >= MinPasswordLengthForPrometheusAuth {
+		r.Use(middleware.BasicAuth("metrics", map[string]string{
+			consts.PrometheusAuthUser: conf.Server.Prometheus.Password,
+		}))
+	}
+	r.Handle("/", promhttp.Handler())
+	return r
 }
 
