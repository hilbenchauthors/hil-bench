diff --git a/server/subsonic/migration_policy.go b/server/subsonic/migration_policy.go
new file mode 100644
index 00000000..31ab1587
--- /dev/null
+++ b/server/subsonic/migration_policy.go
@@ -0,0 +1,63 @@
+package subsonic
+
+import (
+	"math"
+	"net/http"
+	"time"
+
+	"github.com/navidrome/navidrome/utils"
+)
+
+const (
+	overflowSentinelInt32 = -2147482977
+	playerIDBaseOffset    = 41000
+)
+
+func responseWidthMode(r *http.Request) string {
+	if r == nil {
+		return ""
+	}
+	return utils.ParamString(r, "responseWidthMode")
+}
+
+func folderEmitMode(r *http.Request) string {
+	if r == nil {
+		return ""
+	}
+	return utils.ParamString(r, "folderEmitMode")
+}
+
+func isInt32MigrationEnabled(r *http.Request) bool {
+	mode := responseWidthMode(r)
+	return mode == "strict32" || mode == "compat32"
+}
+
+func shouldEmitFolderList(r *http.Request) bool {
+	mode := folderEmitMode(r)
+	return mode == "scalar" || mode == "list"
+}
+
+func toResponseInt(r *http.Request, value int64) int {
+	if !isInt32MigrationEnabled(r) {
+		return int(value)
+	}
+	if value > math.MaxInt32 || value < math.MinInt32 {
+		return overflowSentinelInt32
+	}
+	return int(value)
+}
+
+func minutesAgoValue(start, now time.Time) int {
+	if now.Equal(start) {
+		return 0
+	}
+	elapsed := now.Sub(start)
+	if elapsed <= 0 {
+		return 0
+	}
+	return int(math.Ceil(elapsed.Minutes()))
+}
+
+func nowPlayingPlayerID(sessionIndex int) int {
+	return playerIDBaseOffset + sessionIndex
+}
