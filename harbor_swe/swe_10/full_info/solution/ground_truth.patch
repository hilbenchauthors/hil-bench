+    def get_locally_reachable_ips(self, ip_path):
+        locally_reachable_ips = {
+            'ipv4': [],
+            'ipv6': [],
+        }
+
+        def canonicalize(value):
+            if '/' in value:
+                return str(ipaddress.ip_network(value, strict=False))
+            return str(ipaddress.ip_address(value))
+
+        def parse_locally_reachable_ips(output, family):
+            seen = set()
+            for line in output.splitlines():
+                if not line:
+                    continue
+                words = line.split()
+                if words[0] != 'local':
+                    continue
+                try:
+                    src_idx = words.index('src')
+                    raw_value = words[src_idx + 1]
+                except (ValueError, IndexError):
+                    continue
+                try:
+                    normalized = canonicalize(raw_value)
+                except ValueError:
+                    continue
+                if normalized not in seen:
+                    seen.add(normalized)
+                    locally_reachable_ips[family].append(normalized)
+
+        commands = {
+            'ipv4': [ip_path, '-4', 'route', 'list', 'table', '255'],
+            'ipv6': [ip_path, '-6', 'route', 'list', 'table', '255'],
+        }
+        for family, args in commands.items():
+            rc, routes, _ = self.module.run_command(args)
+            if rc == 0:
+                parse_locally_reachable_ips(routes, family)
+
+        for fam in ('ipv4', 'ipv6'):
+            locally_reachable_ips[fam].sort()
+
+        has_any_values = bool(locally_reachable_ips['ipv4'] or locally_reachable_ips['ipv6'])
+        if not has_any_values:
+            warn = getattr(self.module, 'warn', None)
+            if callable(warn):
+                warn('[net-facts] snr: no scope-host rows')
+
+        return locally_reachable_ips
+
