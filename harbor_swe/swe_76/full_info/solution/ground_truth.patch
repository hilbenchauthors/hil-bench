+func typeKey[T any]() string {
+	return reflect.TypeOf((*T)(nil)).Elem().String()
+}
+
+func normalizeSuffix(nameSuffixes ...string) string {
+	if len(nameSuffixes) == 0 {
+		return ""
+	}
+	if len(nameSuffixes) > 1 {
+		panic("singleton namespace accepts at most one suffix")
+	}
+
+	normalized := strings.TrimSpace(nameSuffixes[0])
+	if normalized == "" {
+		return ""
+	}
+
+	return "::" + normalized
+}
+
+func getKeyLock(key string) *sync.Mutex {
+	lock, _ := keyLocks.LoadOrStore(key, &sync.Mutex{})
+	return lock.(*sync.Mutex)
+}
+
+func shouldCacheInstance[T any](value T) bool {
+	v := any(value)
+	if v == nil {
+		return false
+	}
+
+	rv := reflect.ValueOf(v)
+	switch rv.Kind() {
+	case reflect.Pointer, reflect.Interface, reflect.Map, reflect.Slice, reflect.Chan, reflect.Func:
+		return !rv.IsNil()
+	default:
+		return true
+	}
 }
