+// GetInstance returns a shared instance of type T.
+//
+// The constructor is executed only when an instance for the computed key does not
+// exist yet. A single optional namespace suffix can be used when callers need
+// multiple logical singletons for the same static type.
+func GetInstance[T any](constructor func() T, nameSuffixes ...string) T {
+	key := typeKey[T]() + normalizeSuffix(nameSuffixes...)
+
+	if value, ok := instances.Load(key); ok {
+		return value.(T)
+	}
+
+	lock := getKeyLock(key)
+	lock.Lock()
+	defer lock.Unlock()
+
+	if value, ok := instances.Load(key); ok {
+		return value.(T)
+	}
+
+	created := constructor()
+	if shouldCacheInstance(created) {
+		instances.Store(key, created)
+		log.Trace("Created new singleton", "key", key, "instance", created)
+	}
+
+	return created
 }
 
