-)
+	slices.SortFunc(a.Genres, func(a, b Genre) bool { return a.ID > b.ID })
+	seenIDs := map[string]bool{}
+	unique := a.Genres[:0]
+	for _, g := range a.Genres {
+		if !seenIDs[g.ID] {
+			seenIDs[g.ID] = true
+			unique = append(unique, g)
+		}
+	}
+	a.Genres = unique
+	a.MbzArtistID = dominantMbzID(mbzArtistIDs)
+	return a
+}
+
+func dominantMbzID(ids []string) string {
+	if len(ids) == 0 {
+		return ""
+	}
+	freq := map[string]int{}
+	best := ids[0]
+	bestCount := 0
+	for _, id := range ids {
+		freq[id]++
+		if freq[id] >= bestCount {
+			best = id
+			bestCount = freq[id]
+		}
+	}
+	return best
+}
 
