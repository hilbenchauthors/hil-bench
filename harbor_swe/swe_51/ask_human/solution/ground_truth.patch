diff --git a/utils/gg/gg.go b/utils/gg/gg.go
index 6da9082a..87f15e82 100644
--- a/utils/gg/gg.go
+++ b/utils/gg/gg.go
@@ -30,3 +30,17 @@ func FirstOr[T comparable](or T, values ...T) T {
 	// If all the input values are zero, return the default value.
 	return or
 }
+
+// P returns a pointer to the input value.
+func P[T any](v T) *T {
+	return &v
+}
+
+// V returns the value of the input pointer, or the zero value of the type if the pointer is nil.
+func V[T any](p *T) T {
+	if p == nil {
+		var zero T
+		return zero
+	}
+	return *p
+}
