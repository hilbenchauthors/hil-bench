+func (t Tags) getGainValue(tagNames ...string) float64 {
+	const r128ToReplayGainOffsetDb = 4.637
+
+	for _, tagName := range tagNames {
+		tag, present := t.getLastTagValueIfPresent(tagName)
+		if !present {
+			continue
+		}
+		if tag == "" {
+			log.Warn("Missing gain tag value", "file", t.filePath, "tag", tagName)
+			return 0
+		}
+
+		switch {
+		case strings.HasPrefix(tagName, "r128_"):
+			// R128 gain is a Q7.8 fixed-point integer (dB * 256).
+			i, err := strconv.Atoi(strings.TrimSpace(tag))
+			if err != nil {
+				log.Warn("Invalid gain tag value", "file", t.filePath, "tag", tagName, "value", tag, err)
+				return 0
+			}
+			return (float64(i) / 256.0) + r128ToReplayGainOffsetDb
+		default:
+			// Gain is usually in the form [-]a.bb dB (but may be a bare number).
+			cleaned := strings.TrimSpace(strings.Replace(tag, "dB", "", 1))
+			value, err := strconv.ParseFloat(cleaned, 64)
+			if err != nil || math.IsInf(value, 0) || math.IsNaN(value) {
+				log.Warn("Invalid gain tag value", "file", t.filePath, "tag", tagName, "value", tag, err)
+				return 0
+			}
+			return value
+		}
 	}
-	return value
+
+	// All candidate tags were absent: safe default + noise an error.
+	log.Warn("Missing gain tag value", "file", t.filePath, "tag", strings.Join(tagNames, "|"))
+	return 0
 }
 
