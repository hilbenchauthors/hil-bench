+import { canonizeEmail } from '@proton/shared/lib/helpers/email';
+import { UserSettings } from '@proton/shared/lib/interfaces';
+import { eoDefaultUserSettings } from '@proton/shared/lib/mail/eo/constants';
+
+export const getSenderReferralUserSettings = (
+    primaryAddressEmail: string | undefined,
+    senderAddressEmail: string | undefined,
+    userSettings: Partial<UserSettings> = {}
+) =>
+    primaryAddressEmail &&
+    senderAddressEmail &&
+    canonizeEmail(primaryAddressEmail) === canonizeEmail(senderAddressEmail) &&
+    userSettings.Referral
+        ? userSettings
+        : eoDefaultUserSettings;
