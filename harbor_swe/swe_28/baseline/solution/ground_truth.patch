+def _append_history_event(info):
+    if not job_path:
+        return
+
+    event_name = None
+    if info.get('started') == 1 and info.get('finished') == 0:
+        event_name = 'started'
+    elif info.get('finished') == 1:
+        if info.get('timed_out'):
+            event_name = 'timeout'
+        elif info.get('failed'):
+            event_name = 'failed'
+        else:
+            event_name = 'finished'
+
+    if not event_name:
+        return
+
+    history_event = {
+        'event': event_name,
+        'ts_ms': int(time.time() * 1000),
+        'ansible_job_id': info.get('ansible_job_id'),
+    }
+    if info.get('child_pid') is not None:
+        history_event['child_pid'] = info.get('child_pid')
+
+    history_path = '%s.history' % job_path
+    with open(history_path, 'a') as history_file:
+        history_file.write(json.dumps(history_event, separators=(',', ':')))
+        history_file.write('\n')
+
+
+def end(res=None, exit_msg=0):
+    if res is not None:
+        normalized = _normalize_diagnostic_payload(res)
+        print(json.dumps(normalized))
+        sys.stdout.flush()
+    sys.exit(exit_msg)
+
+
+def jwrite(info):
+    if not job_path:
+        raise RuntimeError('job_path is not initialized')
+
+    normalized = _normalize_diagnostic_payload(info)
+    if job_id is not None:
+        normalized['ansible_job_id'] = job_id
+    tmp_job_path = job_path + '.tmp'
+
+    try:
+        with open(tmp_job_path, 'w') as jobfile:
+            jobfile.write(json.dumps(normalized))
+        os.rename(tmp_job_path, job_path)
+        _append_history_event(normalized)
+    except Exception as e:
+        notice('jwrite failed: %s' % to_text(e))
+        raise
