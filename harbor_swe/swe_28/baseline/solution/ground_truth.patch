+def _escaped_json_length(value):
+    escaped_json = json.dumps(to_text(value, errors='surrogate_or_strict'))
+    # Strip surrounding quotes to measure just the serialized field value bytes.
+    return len(to_bytes(escaped_json[1:-1], errors='surrogate_or_strict'))
+
+
+def _cap_inline_diagnostic(value):
+    text_value = to_text(value, errors='surrogate_or_strict')
+    if _escaped_json_length(text_value) <= DIAGNOSTIC_INLINE_BYTE_CAP:
+        return text_value
+
+    low = 0
+    high = len(text_value)
+    best_value = text_value
+
+    while low <= high:
+        mid = (low + high) // 2
+        dropped_head = to_bytes(text_value[:mid], errors='surrogate_or_strict')
+        marker = TRUNCATED_HEAD_TEMPLATE.format(len(dropped_head))
+        candidate = marker + text_value[mid:]
+        candidate_size = _escaped_json_length(candidate)
+
+        if candidate_size <= DIAGNOSTIC_INLINE_BYTE_CAP:
+            best_value = candidate
+            high = mid - 1
+        else:
+            low = mid + 1
+
+    return best_value
+
+
+def _normalize_diagnostic_payload(payload):
+    if not isinstance(payload, dict):
+        return payload
+
+    normalized = dict(payload)
+    for field in DIAGNOSTIC_FIELDS:
+        if field in normalized and normalized[field] is not None:
+            normalized[field] = _cap_inline_diagnostic(normalized[field])
+    return normalized
+
