+def add_tasknoplay_options(parser):
+    """Add task timeout options for commands that run standalone tasks."""
+    parser.add_argument('--task-timeout', dest='task_timeout', type=int, default=C.TASK_TIMEOUT,
+                        help="must be positive integer. 0 disables the task timeout. set task timeout limit in seconds")
+
+
+def validate_task_timeout(value):
+    """Validate task timeout policy and return the normalized value."""
+    if value < 0:
+        raise AnsibleOptionsError(
+            "The task timeout value (%d) must be 0 (disabled) or a positive integer" % value
+        )
+    if value > 7200:
+        raise AnsibleOptionsError(
+            "The task timeout value (%d) exceeds the maximum allowed timeout of 7200 seconds" % value
+        )
+    if 1 <= value <= 4:
+        raise AnsibleOptionsError(
+            "The task timeout value (%d) is too small; enabled timeouts must be 0 (disabled) or at least 5 seconds" % value
+        )
+    if 10 <= value <= 59 and value % 10 != 0:
+        raise AnsibleOptionsError(
+            "The task timeout value (%d) must be a multiple of 10 for timeouts from 10 through 59 seconds" % value
+        )
+    return value
+
+
+def get_effective_task_timeout(task_timeout, async_val, poll):
+    """Compute the effective timeout when async execution is involved."""
+    async_timeout = async_val if async_val and async_val > 0 else 0
+
+    if task_timeout > 0 and async_timeout > 0:
+        return task_timeout
+    if task_timeout > 0:
+        return task_timeout
+    if async_timeout > 0:
+        return async_timeout
+    return 0
+
+
