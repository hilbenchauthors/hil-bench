+func normalizeLoadArgs(args []any) (context.Context, string, error) {
+	switch len(args) {
+	case 1:
+		path, ok := args[0].(string)
+		if !ok {
+			return nil, "", errInvalidLoadArgs
+		}
+		return context.Background(), path, nil
+	case 2:
+		ctx, err := normalizeContextArg(args[0])
+		if err != nil {
+			return nil, "", err
+		}
+
+		path, ok := args[1].(string)
+		if !ok {
+			return nil, "", errInvalidLoadArgs
+		}
+		return ctx, path, nil
+	default:
+		return nil, "", errInvalidLoadArgs
+	}
+}
+
+func normalizeContextArg(arg any) (context.Context, error) {
+	if arg == nil {
+		return context.Background(), nil
+	}
+
+	ctx, ok := arg.(context.Context)
+	if !ok {
+		return nil, errInvalidLoadArgs
+	}
+
+	// typed-nil values can survive interface conversion and must normalize.
+	if isNilLikeContext(ctx) {
+		return context.Background(), nil
+	}
+
+	return ctx, nil
+}
+
+func isNilLikeContext(ctx context.Context) bool {
+	if ctx == nil {
+		return true
+	}
+	v := reflect.ValueOf(ctx)
+	switch v.Kind() {
+	case reflect.Chan, reflect.Func, reflect.Interface, reflect.Map, reflect.Pointer, reflect.Slice:
+		return v.IsNil()
+	default:
+		return false
+	}
+}
