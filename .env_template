# ============================================
# Shared credentials (agents + ask_human judge)
# ============================================
# Option A: LiteLLM proxy
LITELLM_API_KEY=""
LITELLM_BASE_URL=""
#
# Option B: Direct provider via LiteLLM
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY=""
XAI_API_KEY=""
#
# Option C: Self-hosted auth tokens (optional; only if your endpoint requires auth)
# You can reference these from config files via:
# - Judge config: hosting.self_hosted_api_key_env
# - Agent config: agent.model.api_key: "$<ENV_VAR_NAME>"
ASK_HUMAN_VLLM_API_KEY=""
AGENT_VLLM_API_KEY=""

# ======================
# Where to set BASE URLs
# ======================
# Values live in .env. Config YAMLs should reference env var names.
#
# - Agent model base URL vars (you can define one per mapped agent config):
AGENT_SQL_BASE_URL=""
AGENT_SWE_BASE_URL=""
#
# - ask_human judge base URL var:
ASK_HUMAN_SELF_HOSTED_BASE_URL="http://127.0.0.1:8808"
#
# Then reference them in config files:
# - Agent config: hosting.api_base_env: AGENT_SQL_BASE_URL (or AGENT_SWE_BASE_URL)
# - Judge config: hosting.self_hosted_base_url_env: ASK_HUMAN_SELF_HOSTED_BASE_URL

# ====================
# Optional local caches
# ====================
HF_HOME=""
HUGGINGFACE_HUB_CACHE=""
TRANSFORMERS_CACHE=""
SENTENCE_TRANSFORMERS_HOME=""
